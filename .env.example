# Entorno local
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000

# Privacidad: no persistir facturas ni resultados por defecto.
# Activar SOLO si se necesita auditoría temporal controlada.
STORE_INPUT_FILES=false
STORE_EXTRACTION_RESULTS=false

# Debug explícito. Mantener desactivado salvo durante desarrollo controlado.
INCLUDE_DEBUG_ARTIFACTS=false

# ----------------------------------------------------------------------
# VLM local (perfil 'vlm' — desactivado por defecto)
# Requiere GPU NVIDIA con soporte CUDA.
# ----------------------------------------------------------------------
VLLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
VLLM_HOST=0.0.0.0
VLLM_PORT=8001
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_GPU_MEMORY_UTILIZATION=0.85
